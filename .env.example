# =========================================
# Zimo Live Backend — Environment Variables
# Copy to .env and fill in values
# =========================================

# Runtime
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# MongoDB — use your own cluster (Atlas or self-hosted)
MONGODB_URI=mongodb://localhost:27017/party_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Use DIFFERENT secrets for user vs admin (defense in depth)
# ---------------------------------------------------------------------------

# User auth
JWT_ACCESS_SECRET=change_me_user_access_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_user_refresh_secret_at_least_32_chars_long
JWT_REFRESH_EXPIRES=30d

# Admin auth (SEPARATE secrets)
JWT_ADMIN_ACCESS_SECRET=change_me_admin_access_secret_at_least_32_chars_long
JWT_ADMIN_ACCESS_EXPIRES=30m
JWT_ADMIN_REFRESH_SECRET=change_me_admin_refresh_secret_at_least_32_chars_long
JWT_ADMIN_REFRESH_EXPIRES=7d

# Security
BCRYPT_ROUNDS=12

# OTP
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# CORS (comma-separated origins). MUST include every origin from which
# the frontend is served — origins differ by scheme + host + port, so
# http://example.com and https://example.com are distinct, as are
# :3000 and :3001 on the same host. Empty = allow all (dev only).
#
# Origins to include:
#   :3001  admin panel        :3002  games server (static nginx)
#   :5173  local games dev server (python dev-server.py / http-server)
#   https://games.zimolive.com  production games host — REQUIRED so the
#     WebView-hosted game (loaded from that origin) can call this API.
# Entries prefixed `re:` are regex — the two below allow any LAN IP and
# the Android emulator host on any port so dev WebViews work without
# editing this on every Wi-Fi switch.
# Production VPS example: include the panel + games public origins.
CORS_ORIGIN=http://localhost:3001,http://localhost:5173,http://31.97.15.225:3001,http://31.97.15.225:3002,https://zimolive.com,https://www.zimolive.com,https://api.zimolive.com,https://games.zimolive.com,re:^http://192\.168\.\d+\.\d+:\d+$,re:^http://10\.0\.2\.2:\d+$

# Rate Limiting
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# Super Admin bootstrap (seeded on first boot if DB has no admins)
SUPER_ADMIN_EMAIL=admin@zimolive.com
SUPER_ADMIN_PASSWORD=ChangeMe!2026
SUPER_ADMIN_USERNAME=superadmin

# SMS (stub for dev)
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email — SMTP (Gmail app password works here)
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@zimolive.com
SENDGRID_API_KEY=

# Firebase — required for verifying mobile sign-ins AND for FCM push
# sends. `FIREBASE_PROJECT_ID` alone is enough for token verification;
# FCM sends additionally require a service-account JSON (either an
# inline string or a file path — never commit either).
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Google Sign-In — Firebase Web Client ID(s), comma-separated.
GOOGLE_CLIENT_IDS=

# Agora (fill when ready)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=ml_default

# RevenueCat — wallet recharge billing.
# REVENUECAT_WEBHOOK_AUTH is the literal string put in the
# `Authorization` header on every webhook delivery. Configure it under
# RevenueCat → Project → Integrations → Webhooks. Without this set,
# the receiver rejects all incoming traffic.
REVENUECAT_WEBHOOK_AUTH=
# Set to true ONLY in staging/dev so SANDBOX-environment events
# credit coins. Keep false in production so test purchases by your
# QA team can't mint live coins.
REVENUECAT_ACCEPT_SANDBOX=false
CLOUDINARY_FOLDER=party-app
